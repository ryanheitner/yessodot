{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Yessodot Website Content",
  "type": "object",
  "required": ["meta", "hero", "crisis", "atmosphere", "approach", "science", "evidence", "partners", "leadership", "donate"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["pageTitle", "copyrightYear"],
      "properties": {
        "pageTitle": { "type": "string", "minLength": 1, "maxLength": 200 },
        "copyrightYear": { "type": "string", "pattern": "^\\d{4}$" }
      }
    },
    "hero": {
      "type": "object",
      "required": ["eyebrow", "headlineBefore", "headlineEmphasis", "headlineAfter", "tagline", "videoUrl", "ctaPrimary", "ctaSecondary"],
      "properties": {
        "eyebrow": { "type": "string", "maxLength": 50 },
        "headlineBefore": { "type": "string", "maxLength": 80 },
        "headlineEmphasis": { "type": "string", "maxLength": 40 },
        "headlineAfter": { "type": "string", "maxLength": 80 },
        "tagline": { "type": "string", "maxLength": 500 },
        "videoUrl": { "type": "string", "maxLength": 100 },
        "ctaPrimary": { "type": "string", "maxLength": 50 },
        "ctaSecondary": { "type": "string", "maxLength": 50 }
      }
    },
    "crisis": {
      "type": "object",
      "required": ["eyebrow", "title", "paragraphs", "stat1", "stat2", "stat3"],
      "properties": {
        "eyebrow": { "type": "string", "maxLength": 50 },
        "title": { "type": "string", "maxLength": 120 },
        "paragraphs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "items": { "type": "string", "maxLength": 1000 }
        },
        "stat1": { "$ref": "#/definitions/stat" },
        "stat2": { "$ref": "#/definitions/stat" },
        "stat3": { "$ref": "#/definitions/stat" }
      }
    },
    "atmosphere": {
      "type": "object",
      "required": ["quote", "attribution", "imageAlt"],
      "properties": {
        "quote": { "type": "string", "maxLength": 300 },
        "attribution": { "type": "string", "maxLength": 100 },
        "imageAlt": { "type": "string", "maxLength": 300 }
      }
    },
    "approach": {
      "type": "object",
      "required": ["eyebrow", "title", "lead", "pillar1", "pillar2", "pillar3"],
      "properties": {
        "eyebrow": { "type": "string", "maxLength": 50 },
        "title": { "type": "string", "maxLength": 120 },
        "lead": { "type": "string", "maxLength": 500 },
        "pillar1": { "$ref": "#/definitions/pillar" },
        "pillar2": { "$ref": "#/definitions/pillar" },
        "pillar3": { "$ref": "#/definitions/pillar" }
      }
    },
    "science": {
      "type": "object",
      "required": ["eyebrow", "title", "lead", "point1", "point2", "point3", "point4"],
      "properties": {
        "eyebrow": { "type": "string", "maxLength": 50 },
        "title": { "type": "string", "maxLength": 120 },
        "lead": { "type": "string", "maxLength": 500 },
        "point1": { "$ref": "#/definitions/sciencePoint" },
        "point2": { "$ref": "#/definitions/sciencePoint" },
        "point3": { "$ref": "#/definitions/sciencePoint" },
        "point4": { "$ref": "#/definitions/sciencePoint" }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["eyebrow", "title", "lead", "source", "captionBold", "caption", "chartAlt"],
      "properties": {
        "eyebrow": { "type": "string", "maxLength": 50 },
        "title": { "type": "string", "maxLength": 120 },
        "lead": { "type": "string", "maxLength": 800 },
        "source": { "type": "string", "maxLength": 200 },
        "captionBold": { "type": "string", "maxLength": 200 },
        "caption": { "type": "string", "maxLength": 1000 },
        "chartAlt": { "type": "string", "maxLength": 500 }
      }
    },
    "partners": {
      "type": "object",
      "required": ["eyebrow", "title", "lead", "partner1", "partner2", "partner3"],
      "properties": {
        "eyebrow": { "type": "string", "maxLength": 50 },
        "title": { "type": "string", "maxLength": 120 },
        "lead": { "type": "string", "maxLength": 500 },
        "partner1": { "$ref": "#/definitions/partner" },
        "partner2": { "$ref": "#/definitions/partner" },
        "partner3": { "$ref": "#/definitions/partner" }
      }
    },
    "leadership": {
      "type": "object",
      "required": ["eyebrow", "title", "lead", "leader1", "leader2", "leader3"],
      "properties": {
        "eyebrow": { "type": "string", "maxLength": 50 },
        "title": { "type": "string", "maxLength": 120 },
        "lead": { "type": "string", "maxLength": 500 },
        "leader1": { "$ref": "#/definitions/leader" },
        "leader2": { "$ref": "#/definitions/leader" },
        "leader3": { "$ref": "#/definitions/leader" }
      }
    },
    "donate": {
      "type": "object",
      "required": ["eyebrow", "title", "lead", "email", "ctaText", "tier1", "tier2", "tier3", "tier4"],
      "properties": {
        "eyebrow": { "type": "string", "maxLength": 50 },
        "title": { "type": "string", "maxLength": 120 },
        "lead": { "type": "string", "maxLength": 500 },
        "email": { "type": "string", "format": "email", "maxLength": 100 },
        "ctaText": { "type": "string", "maxLength": 50 },
        "tier1": { "$ref": "#/definitions/tier" },
        "tier2": { "$ref": "#/definitions/tier" },
        "tier3": { "$ref": "#/definitions/tier" },
        "tier4": { "$ref": "#/definitions/tier" }
      }
    }
  },
  "definitions": {
    "stat": {
      "type": "object",
      "required": ["value", "label"],
      "properties": {
        "value": { "type": "string", "maxLength": 20 },
        "label": { "type": "string", "maxLength": 500 }
      }
    },
    "pillar": {
      "type": "object",
      "required": ["title", "body"],
      "properties": {
        "title": { "type": "string", "maxLength": 80 },
        "body": { "type": "string", "maxLength": 600 }
      }
    },
    "sciencePoint": {
      "type": "object",
      "required": ["title", "body"],
      "properties": {
        "title": { "type": "string", "maxLength": 80 },
        "body": { "type": "string", "maxLength": 600 }
      }
    },
    "partner": {
      "type": "object",
      "required": ["badge", "name", "description"],
      "properties": {
        "badge": { "type": "string", "maxLength": 30 },
        "name": { "type": "string", "maxLength": 80 },
        "description": { "type": "string", "maxLength": 800 }
      }
    },
    "leader": {
      "type": "object",
      "required": ["name", "title", "bio"],
      "properties": {
        "name": { "type": "string", "maxLength": 80 },
        "title": { "type": "string", "maxLength": 120 },
        "bio": { "type": "string", "maxLength": 800 }
      }
    },
    "tier": {
      "type": "object",
      "required": ["amount", "impact"],
      "properties": {
        "amount": { "type": "string", "maxLength": 20 },
        "impact": { "type": "string", "maxLength": 100 }
      }
    }
  }
}
